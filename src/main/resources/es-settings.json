{
  "analysis": {
    "filter": {
      "pinyin_filter": {
        "type": "pinyin",
        "keep_first_letter": true,
        "keep_separate_first_letter": false,
        "keep_full_pinyin": true,
        "keep_joined_full_pinyin": true,
        "keep_original": true,
        "limit_first_letter_length": 16,
        "lowercase": true
      }
    },
    "analyzer": {
      "ik_pinyin": {
        "tokenizer": "ik_max_word",
        "filter": [
          "lowercase",
          "pinyin_filter"
        ]
      }
    }
  }
}